{
    "preset": "per",
    "rules": {
        "declare_strict_types": true,
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": false,
            "import_functions": false
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true,
        "concat_space": {
            "spacing": "one"
        },
        "phpdoc_align": {
            "align": "left"
        },
        "void_return": true,
        "self_static_accessor": true
    }
}
